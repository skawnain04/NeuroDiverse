import os
from openai import AzureOpenAI

AZURE_OPENAI_ENDPOINT = "https://benchchat.openai.azure.com/"
AZURE_OPENAI_API_KEY = "28b301cb28c347ca8714129af7dc9416"

client = AzureOpenAI(
  azure_endpoint = AZURE_OPENAI_ENDPOINT,
  api_key=AZURE_OPENAI_API_KEY,
  api_version="2024-02-01"
)

topics = (df['Topic_discussed'].astype(str).tolist())
unique_topics = list(set(topics))
chunk_size = 512

responses = []


for i in range(0, len(unique_topics), chunk_size):
    chunk = unique_topics[i:i + chunk_size]
    question = """Here is the list of all ADHD topics I have collected from a community website reported by users.
    I want you to remove duplicated symptoms and responses not related to ADHD and prepare a clean and concise list of the common topics.
    """ + ", ".join(chunk)


    response = client.chat.completions.create(
        model="benchChat",
        messages=[
            {"role": "system", "content": "You are a helpful assistant and expert in Neurodiverse diseases."},
            {"role": "user", "content": question},

    ]
)
responses.append(response.choices[0].message.content)
responses_str =  "\n".join(responses)

with open("/content/drive/MyDrive/Colab Notebooks/RAG/Data/topics.csv","w")as file:
  file_content = file.write(responses_str)
  print(responses_str)

